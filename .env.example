# PostgreSQL baglantısı
DATABASE_URL="postgresql://postgres:0@localhost:5432/kese?schema=public"
PORT=3000
# JWT secret
JWT_SECRET="kese-dev-secret-degistir"
# Token omru (saat) — kullanmayinca cikis suresi; kayan oturum her acilista yeniler. Varsayilan 24.
JWT_TTL_HOURS=8
# AI icgorusu icin yerel/ucretsiz Ollama (opsiyonel). Ollama yoksa placeholder kullanilir.
# Kurulum: https://ollama.com  ->  `ollama pull llama3.2`
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
# Fis OKUMA icin gorsel model (opsiyonel): "llava"
OLLAMA_VISION_MODEL="llava"
